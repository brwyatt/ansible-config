#!/bin/bash
# Reload Valkey certs using CONFIG SET for all instances
{% for port in valkey_instances %}
if systemctl is-active --quiet valkey-server@{{ port }}; then
  valkey-cli -u rediss://admin:{{ valkey_admin_password }}@localhost:{{ port }} CONFIG SET tls-cert-file {{ valkey_ipa_cert_path }}
  sleep 1
  valkey-cli -u rediss://admin:{{ valkey_admin_password }}@localhost:{{ port }} CONFIG SET tls-key-file {{ valkey_ipa_key_path }}
fi
{% endfor %}
