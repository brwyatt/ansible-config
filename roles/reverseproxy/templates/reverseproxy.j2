server {
  server_name {{ " ".join(item.server_names) }};

  listen 80;

  return 301 https://$host$request_uri;
}

server {
  server_name {{ " ".join(item.server_names) }};

  listen 443 ssl http2;

  ssl_certificate /etc/letsencrypt/live/{{ item.server_names[0] }}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/{{ item.server_names[0] }}/privkey.pem;

  include snippets/ssl.conf;

{% if reverseproxy_trusted_proxies is defined %}
{% for proxy in reverseproxy_trusted_proxies %}
  set_real_ip_from {{ proxy }};
{% endfor %}
  real_ip_header X-Forwarded-For;
{ % if reverseproxy_recursive_proxies %}
  real_ip_recursive on;
{% endif %}

{% endif %}
  proxy_set_header Upgrade $http_upgrade;
  proxy_set_header Connection $http_connection;
  proxy_http_version 1.1;
{% for directive in item.server_directives|default([]) %}
{% if loop.first %}

{% endif %}
  {{ directive }}
{% endfor %}
{% if item.sso_enabled|default(false) %}

  include snippets/authelia-auth.conf;
{% endif %}

  location / {
    proxy_set_header Remote-User "";
    proxy_set_header Remote-Groups "";
    proxy_set_header Remote-Name "";
    proxy_set_header Remote-Email "";

{% if item.sso_enabled|default(false) %}
    auth_request /authelia;
    error_page 401 =302 {{ reverseproxy_sso_url }}/?rd=$scheme://$http_host$request_uri;

    auth_request_set $user $upstream_http_remote_user;
    proxy_set_header Remote-User $user;
    auth_request_set $groups $upstream_http_remote_groups;
    proxy_set_header Remote-Groups $groups;
    auth_request_set $name $upstream_http_remote_name;
    proxy_set_header Remote-Name $name;
    auth_request_set $email $upstream_http_remote_email;
    proxy_set_header Remote-Email $email;

{% endif %}
    proxy_pass {{ item.destination }};

    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $http_connection;
    proxy_http_version 1.1;

    add_header X-Served-By $host;

    proxy_redirect off;
    proxy_read_timeout 120;

    proxy_set_header Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Scheme $scheme;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
