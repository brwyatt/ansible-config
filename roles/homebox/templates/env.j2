HBOX_MODE={{ homebox_mode }}
HBOX_WEB_PORT={{ homebox_web_port }}
HBOX_WEB_HOST={{ homebox_web_host }}

HBOX_OPTIONS_HOSTNAME={{ homebox_options_hostname }}
HBOX_OPTIONS_ALLOW_LOCAL_LOGIN={{ homebox_options_allow_local_login | lower }}
HBOX_OPTIONS_ALLOW_REGISTRATION={{ homebox_options_allow_registration | lower }}
HBOX_OPTIONS_TRUST_PROXY={{ homebox_options_trust_proxy | lower }}

{% if homebox_enable_oidc %}
HBOX_OIDC_ENABLED=true
HBOX_OIDC_ISSUER_URL={{ homebox_oidc_issuer_url }}
HBOX_OIDC_CLIENT_ID={{ homebox_oidc_client_id }}
HBOX_OIDC_CLIENT_SECRET={{ homebox_oidc_client_secret }}
HBOX_OIDC_BUTTON_TEXT={{ homebox_oidc_button_text }}
HBOX_OIDC_SCOPES={{ homebox_oidc_scopes }}
HBOX_OIDC_AUTO_REDIRECT={{ homebox_oidc_auto_redirect | lower }}
{% endif %}
