{% if valkey_proxy_tls | default(true) %}
# TLS Frontend
tls-port {{ valkey_proxy_port | default(6379) }}
tls-cert-file /etc/valkey-proxy/certs/proxy.crt
tls-key-file /etc/valkey-proxy/certs/proxy.key
tls-ca-cert-file /etc/ssl/certs/ca-certificates.crt
tls-auth-clients no
{% else %}
port {{ valkey_proxy_port | default(6379) }}
{% endif %}

# TLS Backend to Cluster
# Assuming proxies communicate with cluster nodes via TLS
cluster-tls {{ "yes" if valkey_cluster_tls | default(true) else "no" }}
cluster-tls-ca-cert-file /etc/ssl/certs/ca-certificates.crt

# Bootstrap nodes
{% for host in groups['valkeyservers'] %}
cluster {{ hostvars[host]['ansible_host'] | default(host) }}:{{ valkey_port | default(6379) }}
{% endfor %}

# Auth
# The proxy can forward auth to the cluster
# or use its own. For simplicity, we assume forwarding.
# requirepass is for the proxy itself if needed.

# Persistence/Logging
logfile /var/log/valkey-proxy/proxy.log
loglevel notice

# Connection settings
threads 4
max-clients 10000
